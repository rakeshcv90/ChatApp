require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, '15.1'

prepare_react_native_project!

use_modular_headers!

$RNFirebaseAsStaticFramework = true

target 'ChatApp' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
    )

    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.1'
        build_config.build_settings['CLANG_CXX_LIBRARY'] = 'libc++'
        build_config.build_settings['CLANG_CXX_LANGUAGE_STANDARD'] = 'c++17'
        build_config.build_settings['GCC_CXX_LANGUAGE_STANDARD'] = 'c++17'

        # Prevent any pod from failing the build due to warnings treated as errors
        build_config.build_settings['GCC_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        build_config.build_settings['SWIFT_TREAT_WARNINGS_AS_ERRORS'] = 'NO'
        build_config.build_settings['CLANG_WARN_DOCUMENTATION_COMMENTS'] = 'NO'

        # Skip build-index generation — speeds up CI significantly
        build_config.build_settings['COMPILER_INDEX_STORE_ENABLE'] = 'NO'

        # Fix for Xcode 16.4: react_native_post_install can store OTHER_CPLUSPLUSFLAGS
        # and OTHER_CFLAGS as a Ruby Array. Xcode then serialises the Array's .to_s
        # as a single string "[ -flag1 -flag2, ]" which clang treats as a filename.
        # Flatten any Array values to a proper space-separated string.
        ['OTHER_CPLUSPLUSFLAGS', 'OTHER_CFLAGS'].each do |key|
          val = build_config.build_settings[key]
          if val.is_a?(Array)
            build_config.build_settings[key] = val.join(' ')
          end
        end

        # For gRPC-Core and gRPC-C++: reset OTHER_CPLUSPLUSFLAGS to $(inherited)
        # so React Native's injected Array value is discarded at the project level.
        # xcconfig-level flags (module maps etc.) are still inherited correctly.
        if target.name == 'gRPC-Core' || target.name == 'gRPC-C++'
          build_config.build_settings['OTHER_CPLUSPLUSFLAGS'] = '$(inherited) -Wno-error'
        end

        # For BoringSSL-GRPC: override OTHER_CFLAGS WITHOUT $(inherited) so Xcode
        # ignores xcconfig values entirely. BoringSSL's xcconfig sets
        # -GCC_WARN_INHIBIT_ALL_WARNINGS which clang rejects on arm64 (parsed as -G).
        # Setting directly here (highest priority, no inherited) replaces it with -w.
        if target.name.start_with?('BoringSSL-GRPC')
          build_config.build_settings['OTHER_CFLAGS'] = '-w'
        end
      end
    end

    # Fix BoringSSL-GRPC: -GCC_WARN_INHIBIT_ALL_WARNINGS is invalid for arm64-apple-ios-simulator
    # Clang reads -G as an unsupported flag; remove it. All BoringSSL targets (including
    # subspecs like BoringSSL-GRPC-openssl_grpc) are covered by the ** glob below.
    # The build-settings override above is the primary fix; this is belt-and-suspenders.
    Dir.glob(File.join(__dir__, 'Pods/Target Support Files/**/*.xcconfig')).select { |f| f.include?('BoringSSL') }.each do |xcconfig_path|
      content = File.read(xcconfig_path)
      if content.include?('-GCC_WARN_INHIBIT_ALL_WARNINGS')
        File.write(xcconfig_path, content.gsub('-GCC_WARN_INHIBIT_ALL_WARNINGS', ''))
        puts "Patched BoringSSL xcconfig: #{File.basename(xcconfig_path)}"
      end
    end

    # Patch gRPC basic_seq.h — removes invalid 'template' keyword for Clang compatibility
    [
      'Pods/gRPC-Core/src/core/lib/promise/detail/basic_seq.h',
      'Pods/gRPC-C++/src/core/lib/promise/detail/basic_seq.h'
    ].each do |path|
      full = File.join(__dir__, path)
      next unless File.exist?(full)
      content = File.read(full)
      if content.include?('Traits::template CallSeqFactory')
        File.write(full, content.gsub('Traits::template CallSeqFactory', 'Traits::CallSeqFactory'))
        puts "Patched: #{path}"
      end
    end

    # Patch gRPC promise_like.h — std::result_of removed in newer standards
    [
      'Pods/gRPC-Core/src/core/lib/promise/detail/promise_like.h',
      'Pods/gRPC-C++/src/core/lib/promise/detail/promise_like.h'
    ].each do |path|
      full = File.join(__dir__, path)
      next unless File.exist?(full)
      content = File.read(full)
      if content.include?('std::result_of')
        patched = content
          .gsub('typename std::result_of<F()>::type', 'typename std::invoke_result<F>::type')
          .gsub('std::result_of<F()>::type', 'std::invoke_result<F>::type')
        File.write(full, patched)
        puts "Patched: #{path}"
      end
    end
  end
end
