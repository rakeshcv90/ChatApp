# Firebase Functions environment variables
# Copy this file to .env and fill in your actual values.
# .env is git-ignored — never commit real API keys.

# 2factor.in API key for sending OTP via SMS (Indian numbers only)
# Get your key from: https://2factor.in/cp/
TWOFACTOR_API_KEY=your_2factor_api_key_here

# Service account base64 (for createCustomToken — set in Firebase Console env vars)
# SA_BASE64=<base64 encoded service account JSON>
